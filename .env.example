# ─────────────────────────────────────────────
# GardenVision AI — Environment Variables
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to GitHub.
# ─────────────────────────────────────────────

# Anthropic — used for prompt enhancement
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# Stability AI — used for image generation
# Get yours at https://platform.stability.ai
STABILITY_API_KEY=your_stability_key_here

# Lead form — where to POST enquiries (optional webhook / email service)
# e.g. a Make.com or Zapier webhook URL, or your own endpoint
LEAD_WEBHOOK_URL=

# B2B config (optional — leave blank for generic mode)
NEXT_PUBLIC_COMPANY_NAME=
NEXT_PUBLIC_COMPANY_TAG=
